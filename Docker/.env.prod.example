# Copie para Docker/.env.prod e preencha com valores reais.
# NÃO commite o .env.prod — ele é ignorado pelo git.
#
# Uso:
#   docker compose -f Docker/docker-compose.prod.yaml --env-file Docker/.env.prod up -d --build

# --- Postgres (container) ---
DB_USER=worklog
DB_PASSWORD=troque-esta-senha
DB_NAME=worklog_db

# --- Datasource do app (profile prod) ---
# Host = nome do serviço no compose (postgres). DB_PROD_USER/PASS devem bater
# com DB_USER/DB_PASSWORD acima (mesmo banco).
DB_PROD_URL=jdbc:postgresql://postgres:5432/worklog_db
DB_PROD_USER=worklog
DB_PROD_PASS=troque-esta-senha

# --- Redis ---
# REDIS_HOST = nome do serviço no compose (redis).
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=troque-esta-senha-redis

# --- JWT ---
# JWT_SECRET_KEY deve ser aleatório e forte (>= 256 bits). Ex.:
#   openssl rand -base64 48
JWT_SECRET_KEY=gere-uma-chave-aleatoria-forte
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# --- CORS ---
# Origins do frontend (subdomínio same-site). Vírgula separa múltiplas.
WORKLOG_CORS_ORIGINS=https://app.seu-dominio.com
